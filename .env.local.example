# 카카오맵 JavaScript 앱 키 (브라우저에 노출됨 — 카카오 콘솔에서 도메인 제한 설정 권장)
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_javascript_key

# Supabase (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# (선택) 회사 기준 위치 — 미설정 시 KT광화문빌딩East 가 기본값
# NEXT_PUBLIC_COMPANY_NAME=KT광화문빌딩East
# NEXT_PUBLIC_COMPANY_ADDRESS=서울특별시 종로구 종로3길 33
# NEXT_PUBLIC_COMPANY_LAT=37.5720029
# NEXT_PUBLIC_COMPANY_LNG=126.9788194
